{
  "1": {
    "class_type": "UNETLoader",
    "_meta": {"title": "Diffusion Model"},
    "inputs": {"unet_name": "flux-2-klein-4b.safetensors", "weight_dtype": "default"}
  },
  "2": {
    "class_type": "CLIPLoader",
    "_meta": {"title": "Text Encoder"},
    "inputs": {"clip_name": "qwen_3_4b.safetensors", "type": "flux2", "device": "default"}
  },
  "3": {
    "class_type": "VAELoader",
    "_meta": {"title": "VAE"},
    "inputs": {"vae_name": "flux2-vae.safetensors"}
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Positive Prompt"},
    "inputs": {"text": "", "clip": ["2", 0]}
  },
  "5": {
    "class_type": "ConditioningZeroOut",
    "_meta": {"title": "Negative (zeroed)"},
    "inputs": {"conditioning": ["4", 0]}
  },
  "6": {
    "class_type": "EmptyFlux2LatentImage",
    "_meta": {"title": "Latent Image"},
    "inputs": {"width": 1024, "height": 1024, "batch_size": 1}
  },
  "7": {
    "class_type": "Flux2Scheduler",
    "_meta": {"title": "Scheduler"},
    "inputs": {"steps": 4, "width": 1024, "height": 1024}
  },
  "8": {
    "class_type": "KSamplerSelect",
    "_meta": {"title": "Sampler Select"},
    "inputs": {"sampler_name": "euler"}
  },
  "9": {
    "class_type": "RandomNoise",
    "_meta": {"title": "Noise"},
    "inputs": {"noise_seed": 0}
  },
  "10": {
    "class_type": "CFGGuider",
    "_meta": {"title": "Guider"},
    "inputs": {"model": ["1", 0], "positive": ["4", 0], "negative": ["5", 0], "cfg": 1.0}
  },
  "11": {
    "class_type": "SamplerCustomAdvanced",
    "_meta": {"title": "Sampler"},
    "inputs": {
      "noise": ["9", 0],
      "guider": ["10", 0],
      "sampler": ["8", 0],
      "sigmas": ["7", 0],
      "latent_image": ["6", 0]
    }
  },
  "12": {
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE Decode"},
    "inputs": {"samples": ["11", 0], "vae": ["3", 0]}
  },
  "13": {
    "class_type": "SaveImage",
    "_meta": {"title": "Save Image"},
    "inputs": {"images": ["12", 0], "filename_prefix": "gamentic"}
  }
}
