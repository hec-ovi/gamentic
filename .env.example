# Gamentic stack config. Copy to the repo root and adjust:  cp .env.example .env
# Every variable has a sane default in docker-compose.yml; the one you MUST set is
# LLM_TEXT_MODEL (and MODELS_DIR if your models live elsewhere).

# Host path that holds the GGUF model folders (mounted read-only into containers)
MODELS_DIR=/home/hec/models/gguf

# --- Text LLM (Gemma 4 12B Heretic, Q4_K_M) ---
LLM_TEXT_PORT=8080
# Path to the model file, relative to MODELS_DIR (i.e. inside the container at /models/...)
LLM_TEXT_MODEL=gemma-4-12B-it-heretic/gemma-4-12B-it-heretic-Q4_K_M.gguf
# Reserve the model's FULL native 128K context. Per-slot ctx = LLM_CTX / LLM_PARALLEL.
LLM_CTX=131072
LLM_PARALLEL=1
LLM_ALIAS=gemma-4-12b-heretic

# --- Image (ComfyUI, ROCm / TheRock, Strix Halo) ---
COMFY_PORT=8188
# Persistent ComfyUI models dir on the host (read-write; ComfyUI Manager downloads here)
COMFY_MODELS_DIR=/home/hec/models/comfyui

# --- Image API (REST adapter in front of ComfyUI) ---
IMAGE_API_PORT=9001
IMAGE_DEFAULT_WIDTH=768
IMAGE_DEFAULT_HEIGHT=768
IMAGE_DEFAULT_STEPS=4
# Per-view character sizes (face 1:1 avatar, body 9:16 tall so feet are not cropped)
IMAGE_CHAR_FACE_WIDTH=448
IMAGE_CHAR_FACE_HEIGHT=448
IMAGE_CHAR_BODY_WIDTH=512
IMAGE_CHAR_BODY_HEIGHT=912
IMAGE_GENERATE_TIMEOUT=120
# Max identity reference images honored per /image/generate (klein tops out ~4)
IMAGE_MAX_REFERENCES=4

# --- Orchestrator image knobs ---
IMAGE_SCENE_W=640
IMAGE_SCENE_H=640
IMAGE_VIEW_W=960
IMAGE_VIEW_H=640
# The text model writes image prompts from live context (one extra LLM call per image)
IMAGE_AGENTIC_PROMPTS=true
# Small unlock cards for newly visible items
IMAGE_ITEMS=true
IMAGE_ITEM_SIZE=320
IMAGE_MAX_ITEMS_PER_TURN=2
# Narrator-initiated images (show_image without a player look) at most every N turns
IMAGE_NARRATOR_COOLDOWN_TURNS=4

# --- Orchestrator text knobs ---
INTERPRET_FREE_TEXT=true
CHARACTER_MAX_TOKENS=0
# A/B knob for the 26B hybrid model: request-level enable_thinking on the NARRATOR
# call only (llama.cpp merges it over the server-level chat-template kwargs).
NARRATOR_THINKING=false
# Whole-story memory: the verbatim story window fed to the narrator (beats; also a
# per-game live setting) + the rolling facts-only recap of everything older.
HISTORY_BEATS=80
SUMMARY_ENABLED=true
SUMMARY_EVERY_TURNS=10
SUMMARY_KEEP_TURNS=8
# Turn economy: at most this many voices per narrator reply, each speaking once,
# with a tight total cascade budget. Raise for busier scenes.
MAX_CHARACTER_REACTIONS=2
TURN_MAX_ACTOR_STEPS=4
TURN_MAX_PER_CHARACTER=1

# Character memory: each character's verbatim window of beats THEY witnessed, plus a
# private rolling recap folded in the background once CHAR_SUMMARY_EVERY witnessed
# beats pile up past the newest CHAR_SUMMARY_KEEP_TURNS turns.
CHAR_HISTORY_BEATS=30
CHAR_SUMMARY_ENABLED=true
CHAR_SUMMARY_EVERY=12
CHAR_SUMMARY_KEEP_TURNS=8
CHAR_SUMMARY_MAX_TOKENS=320

# --- Voice (Maya1-3B GGUF on llama.cpp Vulkan + SNAC decode on CPU) ---
VOICE_API_PORT=9002
LLM_VOICE_PORT=9091
LLM_VOICE_MODEL=maya1/maya1-q4_k_m.gguf
LLM_VOICE_CTX=4096

# AMD GPU group IDs on this host (from `getent group render video`)
RENDER_GID=990
VIDEO_GID=44
