# Gamentic stack config. GENERATED from infra/setup/schema.js by:  ./gamentic-setup --write-example
# Quick start: ./gamentic-setup (wizard). By hand: cp .env.example .env and edit.

# --- Models on disk ---
# MODELS_DIR: Folder that holds your GGUF model folders
#   Host path mounted read-only into the model containers. The text and voice model paths below
#   are relative to this folder.
MODELS_DIR=/home/hec/models/gguf
# LLM_TEXT_MODEL: Text model file (relative to the models folder)
#   The one setting you MUST get right for local play. Path of the GGUF file relative to
#   MODELS_DIR (inside the container it appears at /models/...).
LLM_TEXT_MODEL=gemma-4-26B-A4B-it-heretic/gemma-4-26B-A4B-it-heretic.Q4_K_M.gguf
# LLM_ALIAS: Model alias
#   The name the llama.cpp server advertises and the orchestrator requests. Cosmetic unless you
#   point other tools at the server.
LLM_ALIAS=gemma-4-26b-a4b-heretic
# COMFY_MODELS_DIR: ComfyUI models folder
#   Host path for ComfyUI's model store, mounted read-write (ComfyUI Manager downloads
#   checkpoints here).
COMFY_MODELS_DIR=/home/hec/models/comfyui

# --- GPU access ---
# RENDER_GID: render group id
#   The numeric gid of the 'render' group on this host, so containers may use the GPU. Find it
#   with: getent group render. The CLI detects this automatically.
RENDER_GID=990
# VIDEO_GID: video group id
#   The numeric gid of the 'video' group on this host. Find it with: getent group video. The CLI
#   detects this automatically.
VIDEO_GID=44

# --- Inference providers (cloud overrides) ---
# TEXT_PROVIDER: Text provider
#   local = the llama.cpp container (8 stops + thinking). openai = any /chat/completions-
#   compatible cloud; set the base URL, key and model below.
TEXT_PROVIDER=local
# TEXT_BASE_URL: Text base URL
#   Empty = the in-stack llama.cpp server. For cloud: the provider's API base.
TEXT_BASE_URL=
# TEXT_API_KEY: Text API key
#   Sent as Authorization: Bearer when set.
TEXT_API_KEY=
# TEXT_MODEL: Text model
#   Empty = the local alias. For cloud: the provider's model name.
TEXT_MODEL=
# AUDIO_PROVIDER: Audio provider
#   local = Maya1 voice-api. Cloud dialects are implemented against published schemas and pinned
#   by contract tests; live verification is yours.
AUDIO_PROVIDER=local
# AUDIO_BASE_URL: Audio base URL
#   Empty = the in-stack voice-api.
AUDIO_BASE_URL=
# AUDIO_API_KEY: Audio API key
#   Provider key for cloud audio.
AUDIO_API_KEY=
# AUDIO_MODEL: Audio model
#   Provider-specific model name; empty = each dialect's default.
AUDIO_MODEL=
# AUDIO_VOICE_POOL: ElevenLabs voice pool
#   elevenlabs only: comma-separated voice ids that characters map onto deterministically.
AUDIO_VOICE_POOL=
# IMAGE_PROVIDER: Image provider
#   comfy = the local image-api adapter over ComfyUI. openai = gpt-image-2, gemini = nano
#   banana, fal = queue API.
IMAGE_PROVIDER=comfy
# IMAGE_BASE_URL: Image base URL
#   Empty = the in-stack image-api.
IMAGE_BASE_URL=
# IMAGE_API_KEY: Image API key
#   Provider key for cloud images.
IMAGE_API_KEY=
# IMAGE_MODEL: Image model
#   Provider-specific model name; empty = each dialect's default.
IMAGE_MODEL=

# --- Text model server ---
# LLM_TEXT_PORT: Text model port
#   Host port for the llama.cpp text server.
LLM_TEXT_PORT=8080
# LLM_CTX: Context size
#   Reserve the model's FULL native 128K context. Per-slot context = LLM_CTX / LLM_PARALLEL.
LLM_CTX=131072
# LLM_PARALLEL: Parallel slots
#   One slot keeps the whole context for one game; the engine is sequential anyway.
LLM_PARALLEL=1

# --- Image services ---
# COMFY_PORT: ComfyUI port
#   Host port for ComfyUI itself (the image-api talks to it container-to-container).
COMFY_PORT=8188
# IMAGE_API_PORT: Image API port
#   Host port for the REST adapter in front of ComfyUI.
IMAGE_API_PORT=9001
# IMAGE_DEFAULT_WIDTH: Default image width
#   Scene fallback; the orchestrator normally passes sizes explicitly.
IMAGE_DEFAULT_WIDTH=768
# IMAGE_DEFAULT_HEIGHT: Default image height
#   Scene fallback height.
IMAGE_DEFAULT_HEIGHT=768
# IMAGE_DEFAULT_STEPS: Diffusion steps
#   Tuned for the FLUX.2 Klein distilled model; more steps = slower, not necessarily better.
IMAGE_DEFAULT_STEPS=4
# IMAGE_CHAR_FACE_WIDTH: Character face width
#   Face view is a square avatar.
IMAGE_CHAR_FACE_WIDTH=448
# IMAGE_CHAR_FACE_HEIGHT: Character face height
#   Keep equal to the width.
IMAGE_CHAR_FACE_HEIGHT=448
# IMAGE_CHAR_BODY_WIDTH: Character body width
#   Body views are tall 9:16 so feet are not cropped (verified: wider frames crop).
IMAGE_CHAR_BODY_WIDTH=512
# IMAGE_CHAR_BODY_HEIGHT: Character body height
#   Companion to the body width; keep the 9:16 ratio.
IMAGE_CHAR_BODY_HEIGHT=912
# IMAGE_GENERATE_TIMEOUT: Per-image timeout (s)
#   Hard ceiling on one render before the adapter gives up.
IMAGE_GENERATE_TIMEOUT=120
# IMAGE_MAX_REFERENCES: Max reference images
#   Identity references honored per render; klein tops out around 4.
IMAGE_MAX_REFERENCES=4

# --- Image behavior ---
# IMAGE_SCENE_W: Scene art width
#   Orchestrator-side scene render size.
IMAGE_SCENE_W=640
# IMAGE_SCENE_H: Scene art height
#   Scene renders are roughly square.
IMAGE_SCENE_H=640
# IMAGE_VIEW_W: Look snapshot width
#   The wider 'what you see' shots.
IMAGE_VIEW_W=960
# IMAGE_VIEW_H: Look snapshot height
#   Companion height for look shots.
IMAGE_VIEW_H=640
# IMAGE_AGENTIC_PROMPTS: LLM-written image prompts?
#   The text model writes each image prompt from live context (one extra LLM call per image).
#   Off = template prompts.
IMAGE_AGENTIC_PROMPTS=true
# IMAGE_ITEMS: Item unlock cards?
#   Small card renders for newly visible items.
IMAGE_ITEMS=true
# IMAGE_ITEM_SIZE: Item card size
#   Square item card edge in pixels.
IMAGE_ITEM_SIZE=320
# IMAGE_MAX_ITEMS_PER_TURN: Item cards per turn
#   Cap so a generous narrator cannot flood the render queue.
IMAGE_MAX_ITEMS_PER_TURN=2
# IMAGE_NARRATOR_COOLDOWN_TURNS: Narrator image cooldown
#   Narrator-initiated images (show_image without a player look) at most every N turns.
IMAGE_NARRATOR_COOLDOWN_TURNS=4

# --- Story engine tuning ---
# INTERPRET_FREE_TEXT: Interpret free text?
#   Plain typed text is interpreted into say/do/attack/give/whisper before resolving. Off =
#   everything is a 'do'.
INTERPRET_FREE_TEXT=true
# CHARACTER_MAX_TOKENS: Character reply cap (tokens)
#   0 = uncapped; the prompt discipline does the bounding.
CHARACTER_MAX_TOKENS=0
# NARRATOR_THINKING: Narrator thinking?
#   A/B knob for hybrid-thinking models: request-level enable_thinking on the NARRATOR call
#   only. Ignored by providers that do not support it.
NARRATOR_THINKING=true
# HISTORY_BEATS: Story window (beats)
#   The verbatim story window fed to the narrator; older history rides the rolling facts-only
#   recap. Also a per-game live setting.
HISTORY_BEATS=80
# SUMMARY_ENABLED: Rolling recap?
#   Folds everything older than the window into a facts-only summary.
SUMMARY_ENABLED=true
# SUMMARY_EVERY_TURNS: Recap every N turns
#   How often the fold runs.
SUMMARY_EVERY_TURNS=10
# SUMMARY_KEEP_TURNS: Recap keeps newest N
#   The newest turns stay verbatim, never folded.
SUMMARY_KEEP_TURNS=8
# MAX_CHARACTER_REACTIONS: Voices per turn
#   At most this many characters speak per narrator reply. Raise for busier scenes.
MAX_CHARACTER_REACTIONS=2
# TURN_MAX_ACTOR_STEPS: Cascade budget
#   Total actor steps in one turn before the engine closes the beat.
TURN_MAX_ACTOR_STEPS=4
# TURN_MAX_PER_CHARACTER: Speaks per character
#   Each character speaks at most this many times per turn.
TURN_MAX_PER_CHARACTER=1
# CHAR_HISTORY_BEATS: Character memory window
#   Each character's verbatim window of beats THEY witnessed.
CHAR_HISTORY_BEATS=30
# CHAR_SUMMARY_ENABLED: Character recap?
#   Private rolling recap per character, folded in the background.
CHAR_SUMMARY_ENABLED=true
# CHAR_SUMMARY_EVERY: Character recap every N
#   Witnessed beats that pile up before a fold.
CHAR_SUMMARY_EVERY=12
# CHAR_SUMMARY_KEEP_TURNS: Character recap keeps N
#   Newest witnessed turns stay verbatim.
CHAR_SUMMARY_KEEP_TURNS=8
# CHAR_SUMMARY_MAX_TOKENS: Character recap cap
#   Token budget for one character recap.
CHAR_SUMMARY_MAX_TOKENS=320

# --- Voice ---
# VOICE_API_PORT: Voice API port
#   Host port for the Maya1 voice service (inside the network it listens on 8080).
VOICE_API_PORT=9002
# LLM_VOICE_PORT: Voice model port
#   Host port for the Maya1 SNAC-token server.
LLM_VOICE_PORT=9091
# LLM_VOICE_MODEL: Voice model file
#   Maya1 GGUF path relative to the models folder.
LLM_VOICE_MODEL=maya1/maya1-q4_k_m.gguf
# LLM_VOICE_CTX: Voice context size
#   SNAC token generation needs little context.
LLM_VOICE_CTX=4096

# DO NOT EDIT: selects the full local stack (llm-text is the only profiled service). up.sh harness overrides this to run everything except llm-text.
COMPOSE_PROFILES=local
